strict digraph {
cake [node_type=entity, lexicon_key=cake];
cakeBatter [node_type=entity, lexicon_key=cakeBatter];
vanilla [node_type=property, lexicon_key=vanilla];
frosting [node_type=entity, lexicon_key=frosting];
strawberry [node_type=property, lexicon_key=strawberry];
chocolate [node_type=property, lexicon_key=chocolate];
candle [node_type=entity, lexicon_key=candle];
sprinkles [node_type=entity, lexicon_key=sprinkles];
cake -> vanilla [label=flavor, edge_type=property, lexicon_key=flavor];
cake -> frosting [label="decorated_with", edge_type=relationship, lexicon_key="decorated_with"];
frosting -> strawberry [label=flavor, edge_type=property, lexicon_key=flavor];
}
